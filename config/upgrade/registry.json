{
  "packVersionFile": "docs/VERSIONS.md",
  "components": [
    {
      "id": "pack-version",
      "kind": "meta",
      "path": "docs/VERSIONS.md",
      "check": ["version-table"],
      "watch": ["https://github.com/avisheku/copilot-skills/releases"]
    },
    {
      "id": "skills-graph",
      "kind": "skills",
      "path": "config/skills.graph.json",
      "check": ["graph-valid", "abidance-mvp"],
      "watch": ["https://agentskills.io", "https://docs.github.com/copilot"]
    },
    {
      "id": "model-tips",
      "kind": "models",
      "path": "config/models/matrix.json",
      "check": ["tip-cards-exist"],
      "watch": [
        "https://docs.anthropic.com",
        "https://platform.openai.com/docs",
        "https://ai.google.dev/docs"
      ]
    },
    {
      "id": "moa",
      "kind": "orchestration",
      "path": "config/moa/profiles.json",
      "check": ["file-exists"],
      "watch": ["https://github.com/togethercomputer/moa", "https://arxiv.org/abs/2406.04692"]
    },
    {
      "id": "ics-quality",
      "kind": "governance",
      "path": "config/evals/quality-gate.json",
      "check": ["file-exists", "baseline-exists"],
      "watch": ["https://www.promptfoo.dev/docs/integrations/ci-cd/"]
    },
    {
      "id": "compare-tracker",
      "kind": "governance",
      "path": "config/compare/arms.json",
      "check": ["file-exists"],
      "watch": ["https://arxiv.org/html/2605.27922", "https://lmarena.ai"]
    },
    {
      "id": "ci-actions",
      "kind": "ci",
      "path": ".github/workflows/ci.yml",
      "check": ["file-exists"],
      "watch": [
        "https://github.blog/changelog/",
        "https://docs.github.com/en/actions"
      ]
    },
    {
      "id": "hooks-compat",
      "kind": "runtime",
      "path": "docs/COMPAT.md",
      "check": ["file-exists"],
      "watch": ["https://docs.github.com/copilot"]
    },
    {
      "id": "frontier-sources",
      "kind": "sources",
      "path": "docs/SOURCES.md",
      "check": ["sources-populated"],
      "watch": [
        "https://agentskills.io",
        "https://github.blog/changelog/",
        "https://openai.com/index/",
        "https://www.anthropic.com/news",
        "https://deepmind.google/discover/blog/"
      ]
    },
    {
      "id": "defer-backlog",
      "kind": "roadmap",
      "path": "docs/DEFER.md",
      "check": ["file-exists"],
      "watch": []
    },
    {
      "id": "handbook",
      "kind": "instructions",
      "path": "docs/HANDBOOK.md",
      "check": ["verify-blocks"],
      "watch": []
    },
    {
      "id": "gate-flow",
      "kind": "instructions",
      "path": "shared/instructions/gate-flow.md",
      "check": ["file-exists"],
      "watch": ["https://agentskills.io"]
    }
  ],
  "frontierTopics": [
    "agent skills / SKILL.md standards",
    "Copilot hooks plugins fork",
    "model tip / prompting best practices (Anthropic OpenAI Google)",
    "MoA / multi-agent synthesis",
    "eval harnesses / prompt regression / ICS",
    "harness vs model performance (Harness-Bench)",
    "MCP tooling changes",
    "GitHub Actions / token / security changelog"
  ]
}
