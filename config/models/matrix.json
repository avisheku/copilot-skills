{
  "defaultTier": "universal",
  "taskTiers": {
    "orchestrate": "copilot-auto",
    "implement": "copilot-auto",
    "research": "copilot-auto",
    "debug": "copilot-auto"
  },
  "efforts": ["low", "medium", "high", "extra"],
  "families": {
    "copilot-auto": {
      "tipCard": "tips/copilot-auto.md",
      "catalogUrl": "https://docs.github.com/en/copilot/using-github-copilot/ai-models/choosing-the-right-ai-model-for-your-task",
      "discountPct": 10,
      "prefer": true
    },
    "anthropic": { "tipCard": "tips/anthropic.md", "catalogUrl": "https://docs.anthropic.com" },
    "openai": { "tipCard": "tips/openai.md", "catalogUrl": "https://platform.openai.com/docs" },
    "google": { "tipCard": "tips/google.md", "catalogUrl": "https://ai.google.dev/docs" },
    "universal": { "tipCard": "tips/universal.md", "catalogUrl": "" }
  },
  "cells": {
    "implement": {
      "start": { "family": "copilot-auto", "effort": "medium" },
      "escalatePolicy": "effortThenFamily",
      "escalate": [
        { "family": "copilot-auto", "effort": "high", "why": "keep Auto discount; raise effort" },
        { "family": "universal", "effort": "high", "why": "leave Auto; mid named family" },
        { "family": "anthropic", "effort": "medium", "why": "stronger family; reset effort" }
      ],
      "evidenceMin": 3,
      "source": "seed",
      "updatedAt": null
    },
    "orchestrate": {
      "start": { "family": "copilot-auto", "effort": "medium" },
      "escalatePolicy": "effortThenFamily",
      "escalate": [
        { "family": "copilot-auto", "effort": "high", "why": "keep Auto discount" },
        { "family": "universal", "effort": "high", "why": "leave Auto" },
        { "family": "anthropic", "effort": "medium", "why": "stronger family" }
      ],
      "evidenceMin": 3,
      "source": "seed",
      "updatedAt": null
    },
    "research": {
      "start": { "family": "copilot-auto", "effort": "medium" },
      "escalatePolicy": "effortThenFamily",
      "escalate": [
        { "family": "copilot-auto", "effort": "high", "why": "deeper Auto research" },
        { "family": "anthropic", "effort": "medium", "why": "stronger synth" }
      ],
      "evidenceMin": 3,
      "source": "seed",
      "updatedAt": null
    },
    "debug": {
      "start": { "family": "copilot-auto", "effort": "high" },
      "escalatePolicy": "familyThenEffort",
      "escalate": [
        { "family": "anthropic", "effort": "medium", "why": "hard bugs often need stronger family sooner" },
        { "family": "anthropic", "effort": "high", "why": "then raise effort" },
        { "family": "anthropic", "effort": "extra", "why": "last rung" }
      ],
      "evidenceMin": 3,
      "source": "seed",
      "updatedAt": null
    }
  },
  "ladder": {
    "enabled": true,
    "preferEffortBeforeFamily": true,
    "preferDiscountFamily": "copilot-auto",
    "maxSteps": 4,
    "evidenceMin": 3,
    "qualityMin": 0.75,
    "escalateOn": ["error", "deny", "qualityBelow"],
    "stopWhen": ["okAndQualityOk"],
    "cascadeStyle": "FrugalGPT-like sequential until stop judger"
  },
  "injectAt": "worker_boundary",
  "restoreAfterDo": true
}


